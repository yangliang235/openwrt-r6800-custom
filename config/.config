# Célplatform (Netgear R6800)
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_netgear_r6800=y

# Rendszer optimalizálás (hogy gyors legyen)
CONFIG_EXPERT=y
CONFIG_KERNEL_PRINTK=n
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_ethtool=y

# Hálózat - Csak a PPPoE és az alapok
CONFIG_PACKAGE_rp-pppoe-common=y
CONFIG_PACKAGE_rp-pppoe-client=y
CONFIG_PACKAGE_ppp=y
CONFIG_IPV6=n

# A SZENT GRÁL: WolfSSL (Minden mást kinyírunk)
CONFIG_PACKAGE_libwolfssl=y
CONFIG_WOLFSSL_HAS_AESGCM=y
CONFIG_WOLFSSL_HAS_CHACHA=y
CONFIG_WOLFSSL_HAS_POLY1305=y

# WPAD WolfSSL (NEM a basic, hanem a full, hogy minden menjen)
CONFIG_PACKAGE_wpad-wolfssl=y
# Itt a trükk: Explicit módon tiltjuk a többit, hogy ne legyen Error 2
CONFIG_PACKAGE_wpad-basic-mbedtls=n
CONFIG_PACKAGE_wpad-basic-wolfssl=n
CONFIG_PACKAGE_wpad-mbedtls=n

# LuCI - Csak az alap webes felület WolfSSL-el
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl-wolfssl=y
CONFIG_PACKAGE_libustream-wolfssl=y
# Tiltjuk az mbedtls-t, ami a logodban galibát okozott
CONFIG_PACKAGE_libustream-mbedtls=n

# Wi-Fi Driverek (MT7615 az R6800-hoz)
CONFIG_PACKAGE_kmod-mt7615e=y
CONFIG_PACKAGE_kmod-mt7615-firmware=y
CONFIG_PACKAGE_wireless-regdb=y

# Tűzfal (FW4/Nftables az új szabvány)
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_luci-app-firewall=y

# Rootfs - Hogy beleférjen a flashbe
CONFIG_TARGET_ROOTFS_SQUASHFS=y
